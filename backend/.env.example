# ============================================
# J.A.R.V.I.S - LOCAL MODE CONFIGURATION
# No API keys required! Everything runs locally.
# ============================================

# ============ OLLAMA (LLM - Required) ============
# Install from: https://ollama.com
# Then run: ollama serve
# And pull your model: ollama pull qwen2.5-coder-14b-instruct-abliterated:latest

OLLAMA_HOST=http://127.0.0.1:11434

# Your Ollama model (make sure it's downloaded)
# Recommended: ollama pull qwen2.5-coder-14b-instruct-abliterated:latest
# Or: ollama pull llama3.2
OLLAMA_MODEL=qwen2.5-coder-14b-instruct-abliterated:latest

# Optional: Vision model for screen analysis
# Install: ollama pull llava
OLLAMA_VISION_MODEL=llava:latest

# ============ TTS (Text-to-Speech) ============
# Using Windows SAPI - built into Windows, no setup needed!
# Optional ElevenLabs for premium voice (not required)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============ STT (Speech-to-Text) ============
# Using faster-whisper - completely local!
# Options: tiny, base, small, medium, large
# Install: pip install faster-whisper
# For GPU: pip install torch first
WHISPER_MODEL=base

# ============ WEB SEARCH ============
# Using DuckDuckGo - free, no API key needed!
# Optional: Brave Search for better results
# BRAVE_SEARCH_API_KEY=

# ============ SERVER CONFIG ============
JARVIS_PORT=8765
JARVIS_HOST=127.0.0.1

# ============================================
# DEFAULTS (no need to change these)
# ============================================
# JARVIS_LLM=ollama  (always uses Ollama, no OpenAI needed)

# ============================================
# HOW TO SET UP:
# ============================================
# 1. Install Ollama: https://ollama.com
# 2. Run: ollama serve
# 3. Pull model: ollama pull qwen2.5-coder-14b-instruct-abliterated:latest
# 4. Copy this file to .env: copy .env.example .env
# 5. Install Python deps: pip install -r requirements.txt
# 6. Run: python main.py
# 7. Launch Electron app: cd app && npm run dev
# ============================================